---
import skills from '../data/skills.json';

const netSkills = skills.networking_security;
---

<section id="networking" class="py-16 md:py-20 border-b border-zinc-800/60 bg-gradient-to-b from-zinc-950 to-zinc-900/60">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 text-xs font-mono mb-3">
        <span>// NETWORK & SECURITY ENG</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-100">
        Networking & Security Engineering
      </h2>
      <p class="mt-3 text-zinc-400 text-base sm:text-lg leading-relaxed">
        Configuring enterprise network infrastructure, routing topology, firewall policies, and performing low-level socket and packet troubleshooting.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {netSkills.map((item) => (
        <div class="group p-6 rounded-xl bg-zinc-900/60 border border-zinc-800 hover:border-cyan-500/40 hover:bg-zinc-900 transition-all duration-300 flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="p-2 rounded-lg bg-zinc-800/80 text-cyan-400 group-hover:scale-110 transition-transform">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </span>
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-zinc-800 text-zinc-400 capitalize">
                {item.level}
              </span>
            </div>
            <h3 class="text-lg font-bold text-zinc-100 group-hover:text-cyan-400 transition-colors">
              {item.name}
            </h3>
            <p class="mt-2 text-sm text-zinc-400 leading-relaxed">
              {item.context}
            </p>
          </div>
          <div class="mt-6 pt-4 border-t border-zinc-800/60 flex items-center text-xs font-mono text-zinc-500 group-hover:text-cyan-400/80 transition-colors">
            <span>Enterprise Network Skill</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
