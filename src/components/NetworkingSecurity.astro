---
import skills from '../data/skills.json';

const netSkills = skills.networking_security;
---

<section id="networking" class="py-16 md:py-24 border-b border-[var(--color-border)]/60 bg-[var(--bg-gradient-section-alt)] transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-[var(--color-badge-cyan-border)] bg-[var(--color-badge-cyan-bg)] text-[var(--color-badge-cyan-text)] text-xs font-mono mb-3">
        <span>// NETWORK & SECURITY ENG</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)]">
        Networking & Security Engineering
      </h2>
      <p class="mt-3 text-[var(--color-text-secondary)] text-base sm:text-lg leading-relaxed">
        Configuring enterprise network infrastructure, routing topology, firewall policies, and performing low-level socket and packet troubleshooting.
      </p>
    </div>

    <!-- Responsive Cards Grid with Micro-Interactions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {netSkills.map((item) => (
        <div class="interactive-card p-6 rounded-2xl flex flex-col justify-between group border hover:border-cyan-500/40">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="p-2.5 rounded-xl bg-[var(--color-bg-surface-hover)] text-cyan-600 dark:text-cyan-400 group-hover:scale-110 group-hover:bg-cyan-500/20 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-[var(--color-badge-cyan-bg)] text-[var(--color-badge-cyan-text)] capitalize border border-[var(--color-badge-cyan-border)]">
                {item.level}
              </span>
            </div>
            <h3 class="text-lg font-bold text-[var(--color-text-primary)] group-hover:text-cyan-500 dark:group-hover:text-cyan-400 transition-colors">
              {item.name}
            </h3>
            <p class="mt-2.5 text-sm text-[var(--color-text-secondary)] leading-relaxed">
              {item.context}
            </p>
          </div>
          <div class="mt-6 pt-4 border-t border-[var(--color-border)]/60 flex items-center justify-between text-xs font-mono text-[var(--color-text-tertiary)] group-hover:text-cyan-500 dark:group-hover:text-cyan-400 transition-colors">
            <span>Enterprise Network Skill</span>
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
