---
import skills from '../data/skills.json';

const infraSkills = skills.infrastructure;
---

<section id="infrastructure" class="py-16 md:py-24 border-b border-[var(--color-border)]/60 bg-[var(--bg-gradient-section)] transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-[var(--color-badge-emerald-border)] bg-[var(--color-badge-emerald-bg)] text-[var(--color-badge-emerald-text)] text-xs font-mono mb-3">
        <span>// SYSTEMS & SERVER ADMIN</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)]">
        Infrastructure & Systems Reliability
      </h2>
      <p class="mt-3 text-[var(--color-text-secondary)] text-base sm:text-lg leading-relaxed">
        Hands-on experience configuring hypervisors, managing Linux and Windows server OS installations, provisioning RAID arrays, and establishing resilient virtualization environments.
      </p>
    </div>

    <!-- Responsive Cards Grid with Micro-Interactions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {infraSkills.map((item) => (
        <div class="interactive-card p-6 rounded-2xl flex flex-col justify-between group border">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="p-2.5 rounded-xl bg-[var(--color-bg-surface-hover)] text-emerald-600 dark:text-emerald-400 group-hover:scale-110 group-hover:bg-emerald-500/20 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
                </svg>
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-[var(--color-badge-emerald-bg)] text-[var(--color-badge-emerald-text)] capitalize border border-[var(--color-badge-emerald-border)]">
                {item.level}
              </span>
            </div>
            <h3 class="text-lg font-bold text-[var(--color-text-primary)] group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors">
              {item.name}
            </h3>
            <p class="mt-2.5 text-sm text-[var(--color-text-secondary)] leading-relaxed">
              {item.context}
            </p>
          </div>
          <div class="mt-6 pt-4 border-t border-[var(--color-border)]/60 flex items-center justify-between text-xs font-mono text-[var(--color-text-tertiary)] group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors">
            <span>Verified System Skill</span>
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
