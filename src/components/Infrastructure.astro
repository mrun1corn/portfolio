---
import skills from '../data/skills.json';

const infraSkills = skills.infrastructure;
---

<section id="infrastructure" class="py-16 md:py-24 border-b border-zinc-800/60 bg-zinc-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-400 text-xs font-mono mb-3">
        <span>// SYSTEMS & SERVER ADMIN</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-zinc-100">
        Infrastructure & Systems Reliability
      </h2>
      <p class="mt-3 text-zinc-400 text-base sm:text-lg leading-relaxed">
        Hands-on experience configuring hypervisors, managing Linux and Windows server OS installations, provisioning RAID arrays, and establishing resilient virtualization environments.
      </p>
    </div>

    <!-- Responsive Cards Grid with Micro-Interactions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {infraSkills.map((item) => (
        <div class="interactive-card p-6 rounded-2xl bg-zinc-900/70 border border-zinc-800/80 flex flex-col justify-between group">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="p-2.5 rounded-xl bg-zinc-800/90 text-emerald-400 group-hover:scale-110 group-hover:bg-emerald-500/20 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
                </svg>
              </span>
              <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-zinc-800/90 text-zinc-400 capitalize border border-zinc-700/50">
                {item.level}
              </span>
            </div>
            <h3 class="text-lg font-bold text-zinc-100 group-hover:text-emerald-400 transition-colors">
              {item.name}
            </h3>
            <p class="mt-2.5 text-sm text-zinc-400 leading-relaxed">
              {item.context}
            </p>
          </div>
          <div class="mt-6 pt-4 border-t border-zinc-800/60 flex items-center justify-between text-xs font-mono text-zinc-500 group-hover:text-emerald-400/90 transition-colors">
            <span>Verified System Skill</span>
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
