---
import profile from '../data/profile.json';
---

<section id="hero" class="py-16 md:py-24 border-b border-zinc-800/60 bg-gradient-to-b from-zinc-950 via-zinc-950 to-zinc-900/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
      
      <!-- Left Hero Text -->
      <div class="lg:col-span-7 space-y-6">
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-mono">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
          <span>Targeting Meta / Google SRE & Infrastructure Engineering</span>
        </div>

        <div class="space-y-2">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-zinc-100">
            {profile.name} <span class="text-zinc-500 text-2xl sm:text-3xl font-mono">({profile.username})</span>
          </h1>
          <p class="text-xl sm:text-2xl font-mono text-emerald-400 font-semibold">
            {profile.cv_original_title}
          </p>
        </div>

        <p class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-2xl">
          Infrastructure Engineer at <strong class="text-zinc-200 font-medium">{profile.company}</strong> in {profile.location}. 
          Focused on high-performance C++ systems tooling, server administration, Mikrotik/Cisco networking, and production reliability.
        </p>

        <!-- Target Roles Badges -->
        <div class="pt-2 flex flex-wrap gap-2">
          {profile.target_roles.map((role) => (
            <span class="px-2.5 py-1 rounded bg-zinc-900 border border-zinc-800 text-zinc-300 text-xs font-mono">
              #{role}
            </span>
          ))}
        </div>

        <!-- Action Buttons -->
        <div class="pt-4 flex flex-wrap items-center gap-4">
          <a
            href="#portview"
            class="px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-zinc-950 font-semibold font-mono text-sm transition-all shadow-lg shadow-emerald-950/40 flex items-center space-x-2"
          >
            <span>Explore C++ Tools</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
          <a
            href={profile.contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-2.5 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-zinc-200 font-mono text-sm transition-all"
          >
            GitHub Profile
          </a>
          <a
            href={profile.contact.website}
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-2.5 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-zinc-200 font-mono text-sm transition-all"
          >
            mrun1corn.xyz ↗
          </a>
        </div>
      </div>

      <!-- Right Interactive Terminal Widget -->
      <div class="lg:col-span-5">
        <div class="rounded-xl border border-zinc-800 bg-zinc-900/90 shadow-2xl overflow-hidden font-mono text-xs text-zinc-300">
          <div class="bg-zinc-800/80 px-4 py-2.5 border-b border-zinc-700/60 flex items-center justify-between">
            <div class="flex items-center space-x-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80 inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80 inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80 inline-block"></span>
            </div>
            <span class="text-zinc-400 text-xs">robin@bfin-it:~</span>
          </div>
          <div class="p-5 space-y-3 font-mono leading-relaxed">
            <div class="flex items-center space-x-2 text-emerald-400">
              <span>robin@bfin-it:~$</span>
              <span class="text-zinc-100 font-semibold">whoami</span>
            </div>
            <div class="text-zinc-300 pl-4 border-l-2 border-emerald-500/50 space-y-1">
              <p><span class="text-zinc-500">Name:</span> {profile.name} ({profile.username})</p>
              <p><span class="text-zinc-500">Org:</span> {profile.company} (Mohammadpur, Dhaka)</p>
              <p><span class="text-zinc-500">Focus:</span> C++ Systems, Server Admin, Networking</p>
              <p><span class="text-zinc-500">Status:</span> {profile.education[0].credential} ({profile.education[0].institution})</p>
            </div>

            <div class="flex items-center space-x-2 text-emerald-400 pt-2">
              <span>robin@bfin-it:~$</span>
              <span class="text-zinc-100 font-semibold">cat skills_summary.json</span>
            </div>
            <div class="text-zinc-400 pl-4 border-l-2 border-zinc-700 space-y-1">
              <p>{'{'}</p>
              <p class="pl-3"><span class="text-emerald-300">"languages"</span>: ["C++17", "C", "Python", "TypeScript", "Kotlin"],</p>
              <p class="pl-3"><span class="text-emerald-300">"virtualization"</span>: ["Proxmox VE", "VMware", "RAID"],</p>
              <p class="pl-3"><span class="text-emerald-300">"networking"</span>: ["Mikrotik", "Cisco Routers & Switches", "WAF"]</p>
              <p>{'}'}</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
