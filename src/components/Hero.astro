---
import profile from '../data/profile.json';
---

<section id="hero" class="relative py-16 md:py-28 border-b border-zinc-800/60 bg-gradient-to-b from-zinc-950 via-zinc-950 to-zinc-900/60 overflow-hidden">
  
  <!-- Background Glow FX -->
  <div class="absolute top-1/4 left-10 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none animate-pulse-glow"></div>
  <div class="absolute bottom-10 right-10 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none animate-pulse-glow" style="animation-delay: 2s;"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      
      <!-- Left Hero Column -->
      <div class="lg:col-span-7 space-y-6 animate-fade-in-up">
        
        <!-- Target Badge -->
        <div class="inline-flex items-center space-x-2 px-3.5 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-mono shadow-sm">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
          <span>Meta / Google SRE & Infrastructure Engineering</span>
        </div>

        <!-- Title & Headline -->
        <div class="space-y-3">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-zinc-100">
            {profile.name} <span class="text-zinc-500 text-2xl sm:text-3xl font-mono font-normal">(@{profile.username})</span>
          </h1>
          <p class="text-xl sm:text-2xl font-mono text-emerald-400 font-semibold leading-snug">
            {profile.cv_original_title}
          </p>
        </div>

        <p class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-2xl">
          Infrastructure Engineer at <strong class="text-zinc-200 font-semibold">{profile.company}</strong> ({profile.location}). 
          Specializing in high-performance C++ systems tooling, server administration, enterprise networking, and production reliability.
        </p>

        <!-- Target Roles Badges -->
        <div class="pt-1 flex flex-wrap gap-2">
          {profile.target_roles.map((role) => (
            <span class="px-3 py-1 rounded-md bg-zinc-900/90 border border-zinc-800 text-zinc-300 text-xs font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
              #{role}
            </span>
          ))}
        </div>

        <!-- Action Buttons -->
        <div class="pt-4 flex flex-wrap items-center gap-4">
          <a
            href="#portview"
            class="px-6 py-3 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold font-mono text-sm transition-all shadow-lg shadow-emerald-950/50 hover:shadow-emerald-500/20 hover:-translate-y-0.5 flex items-center space-x-2.5 group"
          >
            <span>Explore C++ Tools</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>

          <a
            href="/Robin_Mia_CV.pdf"
            target="_blank"
            download="Robin_Mia_CV.pdf"
            class="px-6 py-3 rounded-xl bg-zinc-900/90 hover:bg-zinc-800 border border-emerald-500/40 text-emerald-400 font-mono text-sm transition-all hover:-translate-y-0.5 flex items-center space-x-2 shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span>Download CV (PDF)</span>
          </a>

          <a
            href={profile.contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 rounded-xl bg-zinc-900/90 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-zinc-200 font-mono text-sm transition-all hover:-translate-y-0.5 flex items-center space-x-2"
          >
            <span>GitHub Profile</span>
            <span class="text-xs text-zinc-400">↗</span>
          </a>
        </div>

      </div>

      <!-- Right Interactive CLI Widget -->
      <div class="lg:col-span-5">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/90 shadow-2xl overflow-hidden font-mono text-xs text-zinc-300 glow-border hover:border-emerald-500/40 transition-all duration-300">
          <div class="bg-zinc-900/90 px-4 py-3 border-b border-zinc-800/80 flex items-center justify-between">
            <div class="flex items-center space-x-2">
              <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500 inline-block"></span>
              <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
            </div>
            <span class="text-zinc-500 text-xs">robin@bfin-it:~ (zsh)</span>
          </div>

          <div class="p-6 space-y-4 font-mono leading-relaxed">
            
            <div class="flex items-center space-x-2 text-emerald-400">
              <span>robin@bfin-it:~$</span>
              <span class="text-zinc-100 font-semibold">whoami</span>
            </div>
            <div class="text-zinc-300 pl-4 border-l-2 border-emerald-500/60 space-y-1">
              <p><span class="text-zinc-500">Name:</span> {profile.name} (@{profile.username})</p>
              <p><span class="text-zinc-500">Org:</span> {profile.company} ({profile.location})</p>
              <p><span class="text-zinc-500">Identity:</span> {profile.portfolio_identity}</p>
              <p><span class="text-zinc-500">Status:</span> {profile.education[0].credential}</p>
            </div>

            <div class="flex items-center space-x-2 text-emerald-400 pt-2">
              <span>robin@bfin-it:~$</span>
              <span class="text-zinc-100 font-semibold">cat skills.json</span>
            </div>
            <div class="text-zinc-400 pl-4 border-l-2 border-zinc-800 space-y-1">
              <p>{'{'}</p>
              <p class="pl-3"><span class="text-emerald-300">"languages"</span>: ["C++", "Kotlin", "Dart", "Java", "Python", "HTML", "CSS", "JS", "React"],</p>
              <p class="pl-3"><span class="text-emerald-300">"infrastructure"</span>: ["Proxmox VE", "VMware", "Server OS"],</p>
              <p class="pl-3"><span class="text-emerald-300">"networking"</span>: ["Mikrotik", "Cisco Routers/Switches", "WAF"]</p>
              <p>{'}'}</p>
            </div>

            <div class="flex items-center space-x-2 text-emerald-400 pt-2">
              <span>robin@bfin-it:~$</span>
              <span class="text-zinc-100 font-semibold animate-pulse">_</span>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>
