---
import projects from '../data/projects.json';

const pinnedList = projects.filter((p) => p.id !== 'portview');
---

<section id="projects" class="py-16 md:py-24 border-b border-[var(--color-border)]/60 bg-[var(--bg-gradient-section-alt)] transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-[var(--color-badge-purple-border)] bg-[var(--color-badge-purple-bg)] text-[var(--color-badge-purple-text)] text-xs font-mono mb-3">
        <span>// GITHUB PINNED REPOSITORIES</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)]">
        Open Source & Software Projects
      </h2>
      <p class="mt-3 text-[var(--color-text-secondary)] text-base sm:text-lg leading-relaxed">
        Featured open-source software, mobile applications, web tools, and full-stack projects directly pinned on GitHub (<a href="https://github.com/mrun1corn" target="_blank" rel="noopener noreferrer" class="text-emerald-600 dark:text-emerald-400 hover:underline font-mono">@mrun1corn</a>).
      </p>
    </div>

    <!-- Pinned Responsive Grid with Micro-Interactions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {pinnedList.map((project) => (
        <div class="interactive-card p-6 rounded-2xl flex flex-col justify-between group border hover:border-purple-500/40">
          <div>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2.5">
                <span class="p-2 rounded-lg bg-[var(--color-bg-surface-hover)] text-purple-600 dark:text-purple-400 group-hover:scale-110 group-hover:bg-purple-500/20 transition-all">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                  </svg>
                </span>
                <h3 class="text-lg font-bold text-[var(--color-text-primary)] group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors font-mono">
                  {project.name}
                </h3>
              </div>
              {project.stars ? (
                <span class="inline-flex items-center space-x-1 text-xs font-mono px-2.5 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-600 dark:text-amber-300">
                  <span>★</span>
                  <span>{project.stars}</span>
                </span>
              ) : (
                <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-[var(--color-bg-surface-hover)] text-[var(--color-text-secondary)] border border-[var(--color-border)]">
                  {project.language}
                </span>
              )}
            </div>

            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
              {project.one_liner}
            </p>
          </div>

          <div class="pt-4 border-t border-[var(--color-border)]/60 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-wrap gap-1.5 max-w-full sm:max-w-[75%]">
              {project.tech_stack?.map((tech) => (
                <span class="px-2 py-0.5 rounded bg-[var(--color-bg-surface-hover)] text-[var(--color-text-secondary)] text-xs font-mono border border-[var(--color-border)]">
                  {tech}
                </span>
              ))}
            </div>
            <a
              href={project.github_url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-mono text-purple-600 dark:text-purple-400 hover:text-purple-500 transition-all inline-flex items-center space-x-1 group-hover:translate-x-0.5 self-end sm:self-auto"
            >
              <span>GitHub</span>
              <span>↗</span>
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
