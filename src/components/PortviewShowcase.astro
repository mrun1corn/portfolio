---
import projects from '../data/projects.json';

const portview = projects.find((p) => p.id === 'portview') || projects[0];
---

<section id="portview" class="py-16 md:py-24 border-b border-zinc-800/60 bg-zinc-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
      <div>
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded border border-emerald-500/20 bg-emerald-500/10 text-emerald-400 text-xs font-mono mb-3">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
          <span>// FLAGSHIP C++ SYSTEM TOOL</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-zinc-100 flex items-center gap-3">
          <span>{portview.name}</span>
          <span class="text-xs font-mono font-normal px-2.5 py-1 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-300">
            C++ / Windows SDK
          </span>
        </h2>
      </div>
      <div class="mt-4 md:mt-0">
        <a
          href={portview.github_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center space-x-2 px-4 py-2 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 text-emerald-400 text-sm font-mono transition-all"
        >
          <span>View Source on GitHub</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Main Showcase Card -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- Left Column: Problem & Architecture -->
      <div class="lg:col-span-7 space-y-6">
        <div class="p-6 sm:p-8 rounded-2xl bg-zinc-900/80 border border-zinc-800 space-y-4">
          <h3 class="text-xl font-bold text-zinc-100 flex items-center space-x-2">
            <span class="text-emerald-400 font-mono">01.</span>
            <span>System Overview & One-Liner</span>
          </h3>
          <p class="text-zinc-300 text-base leading-relaxed">
            {portview.one_liner}
          </p>
          <div class="pt-2 flex flex-wrap gap-2">
            {portview.tech_stack?.map((tech) => (
              <span class="px-2.5 py-1 rounded bg-zinc-800 border border-zinc-700 text-zinc-300 text-xs font-mono">
                {tech}
              </span>
            ))}
            <span class="px-2.5 py-1 rounded bg-emerald-950/60 border border-emerald-800 text-emerald-400 text-xs font-mono">
              MIT License
            </span>
          </div>
        </div>

        <div class="p-6 sm:p-8 rounded-2xl bg-zinc-900/80 border border-zinc-800 space-y-4">
          <h3 class="text-xl font-bold text-zinc-100 flex items-center space-x-2">
            <span class="text-emerald-400 font-mono">02.</span>
            <span>Key Engineering Capabilities</span>
          </h3>
          <ul class="space-y-3 text-sm text-zinc-300">
            <li class="flex items-start space-x-3">
              <span class="text-emerald-400 mt-0.5">▹</span>
              <span><strong>Live Socket Enumeration:</strong> Queries TCP/UDP connection tables directly using Windows IP Helper API (<code class="text-emerald-300 font-mono text-xs">IPHLPAPI</code>).</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-emerald-400 mt-0.5">▹</span>
              <span><strong>PID Process Mapping:</strong> Resolves owner Process IDs to active process executable paths in real time.</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-emerald-400 mt-0.5">▹</span>
              <span><strong>Traffic Inspection & Stats:</strong> Tracks per-connection byte transfer rates and connection states.</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-emerald-400 mt-0.5">▹</span>
              <span><strong>Zero External Dependencies:</strong> Native C++ binary compiled directly against the Windows SDK.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Right Column: Interactive Terminal Preview -->
      <div class="lg:col-span-5">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 shadow-2xl overflow-hidden font-mono text-xs h-full flex flex-col justify-between">
          <div>
            <div class="bg-zinc-900 px-4 py-3 border-b border-zinc-800 flex items-center justify-between">
              <div class="flex items-center space-x-2">
                <span class="w-3 h-3 rounded-full bg-red-500"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                <span class="w-3 h-3 rounded-full bg-green-500"></span>
              </div>
              <span class="text-zinc-400 text-xs">portview.exe -v</span>
            </div>
            <div class="p-5 font-mono text-zinc-300 space-y-2 overflow-x-auto leading-relaxed">
              <p class="text-emerald-400 font-bold">C:\> portview.exe --stats --pid</p>
              <p class="text-zinc-500">Scanning TCP/UDP sockets via IPHLPAPI...</p>
              <p class="text-zinc-400">========================================================</p>
              <p><span class="text-zinc-500">PROTO</span>  <span class="text-zinc-300">LOCAL ADDRESS</span>    <span class="text-zinc-300">FOREIGN ADDRESS</span>  <span class="text-zinc-300">PID</span>   <span class="text-emerald-300">PROCESS</span></p>
              <p><span class="text-cyan-400">TCP</span>    127.0.0.1:8080   0.0.0.0:0        4212  <span class="text-zinc-200">nginx.exe</span></p>
              <p><span class="text-cyan-400">TCP</span>    192.168.1.5:443  104.16.2.1:443   8190  <span class="text-zinc-200">chrome.exe</span></p>
              <p><span class="text-yellow-400">UDP</span>    0.0.0.0:53       0.0.0.0:0        1044  <span class="text-zinc-200">svchost.exe</span></p>
              <p><span class="text-cyan-400">TCP</span>    192.168.1.5:22   192.168.1.1:5212 9012  <span class="text-zinc-200">sshd.exe</span></p>
              <p class="text-zinc-400">========================================================</p>
              <p class="text-emerald-400 font-bold">[+] 4 active sockets mapped across 4 distinct processes.</p>
            </div>
          </div>
          <div class="p-4 bg-zinc-900/60 border-t border-zinc-800/80 text-zinc-400 text-xs flex justify-between items-center">
            <span>Built with C++</span>
            <span class="text-emerald-400">Open Source (MIT)</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
