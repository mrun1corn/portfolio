---
import experience from '../data/experience.json';
import profile from '../data/profile.json';
---

<section id="experience" class="py-16 md:py-24 border-b border-zinc-800/60 bg-zinc-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-3xl mb-12">
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded border border-emerald-500/20 bg-emerald-500/10 text-emerald-400 text-xs font-mono mb-3">
        <span>// CAREER & EXPERIENCE</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-zinc-100">
        Professional Experience & Education
      </h2>
      <p class="mt-3 text-zinc-400 text-base sm:text-lg leading-relaxed">
        Engineering roles in IT infrastructure, system administration, and technical support.
      </p>
    </div>

    <!-- Timeline Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- Left Column: Work Experience -->
      <div class="lg:col-span-8 space-y-8">
        <h3 class="text-xl font-bold text-zinc-200 border-b border-zinc-800 pb-3 font-mono">
          Work History
        </h3>

        <div class="space-y-6">
          {experience.map((item) => (
            <div class="relative pl-6 sm:pl-8 border-l-2 border-zinc-800 hover:border-emerald-500 transition-colors group">
              <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-zinc-950 border-2 border-zinc-700 group-hover:border-emerald-400 group-hover:bg-emerald-500/20 transition-all"></div>
              
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
                <h4 class="text-lg font-bold text-zinc-100 group-hover:text-emerald-400 transition-colors">
                  {item.role} <span class="text-emerald-400 font-normal">@ {item.org}</span>
                </h4>
                <span class="text-xs font-mono px-2.5 py-1 rounded bg-zinc-900 border border-zinc-800 text-zinc-400 w-max">
                  {item.start} — {item.end}
                </span>
              </div>

              {item.portfolio_section && (
                <p class="text-xs text-zinc-500 font-mono mb-3">// {item.portfolio_section}</p>
              )}

              <ul class="space-y-2 text-sm text-zinc-300">
                {(item.raw_bullets || []).map((resp) => (
                  <li class="flex items-start space-x-2">
                    <span class="text-emerald-400 mt-1">▸</span>
                    <span>{resp}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column: Education & Certifications -->
      <div class="lg:col-span-4 space-y-8">
        <div>
          <h3 class="text-xl font-bold text-zinc-200 border-b border-zinc-800 pb-3 font-mono">
            Education
          </h3>
          <div class="mt-6 space-y-4">
            {profile.education.map((edu) => (
              <div class="p-4 rounded-xl bg-zinc-900/60 border border-zinc-800 space-y-1">
                <h4 class="text-sm font-bold text-zinc-100">{edu.credential}</h4>
                <p class="text-xs text-emerald-400 font-mono">{edu.institution}</p>
                <p class="text-xs text-zinc-500">{edu.status ? `${edu.status} (Expected ${edu.expected})` : `${edu.result} — ${edu.year}`}</p>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-xl font-bold text-zinc-200 border-b border-zinc-800 pb-3 font-mono">
            Certifications
          </h3>
          <div class="mt-6 space-y-4">
            {profile.certifications.map((cert) => (
              <div class="p-4 rounded-xl bg-zinc-900/60 border border-zinc-800 space-y-2">
                <div class="flex items-center justify-between">
                  <h4 class="text-sm font-bold text-zinc-100">{cert.name}</h4>
                  <span class="text-xs font-mono text-zinc-500">{cert.year}</span>
                </div>
                <p class="text-xs text-emerald-400 font-mono">{cert.institution} ({cert.duration})</p>
                <ul class="text-xs text-zinc-400 space-y-1 pt-1">
                  {(cert.covered || []).map((cov) => (
                    <li>• {cov}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
