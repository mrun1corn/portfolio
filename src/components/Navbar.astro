---
import profile from '../data/profile.json';

const navItems = [
  { label: 'Overview', href: '#hero' },
  { label: 'Infrastructure', href: '#infrastructure' },
  { label: 'Networking', href: '#networking' },
  { label: 'portview (C++)', href: '#portview' },
  { label: 'Projects', href: '#projects' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800/80 transition-all">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Brand -->
    <a href="#hero" class="flex items-center space-x-2 text-zinc-100 hover:text-emerald-400 transition group">
      <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="font-mono font-bold text-lg tracking-tight">mrun1corn<span class="text-emerald-400">.xyz</span></span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-zinc-400 hover:text-emerald-400 transition-colors py-1"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Socials / Quick Link -->
    <div class="flex items-center space-x-3">
      <a
        href={profile.contact.github}
        target="_blank"
        rel="noopener noreferrer"
        class="px-3 py-1.5 rounded-md bg-zinc-900 border border-zinc-800 text-xs font-mono text-zinc-300 hover:text-emerald-300 hover:border-emerald-500/50 transition-all flex items-center space-x-1.5"
      >
        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</header>
