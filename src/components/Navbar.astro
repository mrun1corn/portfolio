---
import profile from '../data/profile.json';

const navItems = [
  { label: 'Overview', href: '#hero' },
  { label: 'Infrastructure', href: '#infrastructure' },
  { label: 'Networking', href: '#networking' },
  { label: 'portview (C++)', href: '#portview' },
  { label: 'Projects', href: '#projects' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-zinc-950/85 backdrop-blur-lg border-b border-zinc-800/80 transition-all">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Brand -->
    <a href="#hero" class="flex items-center space-x-2.5 text-zinc-100 hover:text-emerald-400 transition-all group">
      <span class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
      </span>
      <span class="font-mono font-bold text-lg tracking-tight group-hover:translate-x-0.5 transition-transform">
        mrun1corn<span class="text-emerald-400">/portfolio</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-zinc-400 hover:text-emerald-400 transition-colors py-1 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-emerald-400 hover:after:w-full after:transition-all"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right Actions & Mobile Hamburger -->
    <div class="flex items-center space-x-3">
      <a
        href={profile.contact.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex px-3.5 py-1.5 rounded-lg bg-zinc-900/90 border border-zinc-800 text-xs font-mono text-zinc-300 hover:text-emerald-300 hover:border-emerald-500/50 hover:scale-105 transition-all shadow-sm flex items-center space-x-2"
      >
        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span>GitHub</span>
      </a>

      <!-- Mobile Menu Toggle Button -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle Navigation Menu"
        class="md:hidden p-2 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 hover:text-emerald-400 transition"
      >
        <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Nav Drawer -->
  <div id="mobile-menu" class="hidden md:hidden border-b border-zinc-800 bg-zinc-950/95 px-4 pt-3 pb-6 space-y-3 font-mono text-sm">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="block px-3 py-2 rounded-lg text-zinc-300 hover:text-emerald-400 hover:bg-zinc-900 transition-colors"
      >
        {item.label}
      </a>
    ))}
    <div class="pt-2 border-t border-zinc-800">
      <a
        href={profile.contact.github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center space-x-2 px-3 py-2 rounded-lg text-emerald-400 bg-emerald-950/40 border border-emerald-800/60"
      >
        <span>GitHub Profile (@mrun1corn)</span>
        <span>↗</span>
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (btn && menu && openIcon && closeIcon) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });

    // Close menu when clicking a link
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        openIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      });
    });
  }
</script>
